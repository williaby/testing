# Cloudflare Access Configuration
# Copy this file to .env and fill in your values

# ==============================================================================
# REQUIRED SETTINGS
# ==============================================================================

# Your Cloudflare team domain (required)
# Find this in your Cloudflare Zero Trust dashboard
# Format: your-team-name.cloudflareaccess.com
CLOUDFLARE_TEAM_DOMAIN=your-team.cloudflareaccess.com

# Application Audience Tag (required)
# Find this in Cloudflare Zero Trust > Access > Applications > Your App > Overview
# It's labeled as "Application Audience (AUD) Tag"
CLOUDFLARE_AUDIENCE_TAG=abc123def456ghi789jkl012mno345pqr678stu901vwx234yz

# ==============================================================================
# EMAIL WHITELIST (NEW!)
# ==============================================================================

# Whitelist of allowed emails/domains (comma-separated)
# Supports individual emails and domain patterns:
# - user@example.com (specific user)
# - @company.com (all users from company.com domain)
WHITELIST=user@example.com,@company.com,admin@example.com

# Admin emails (comma-separated)
# Users with administrative privileges
ADMIN_EMAILS=admin@company.com,boss@company.com

# Full-tier users (comma-separated)
# Users with full access to premium features
# Can include domains: @company.com
FULL_USERS=@company.com,premium@example.com

# Limited-tier users (comma-separated)
# Users with restricted access
LIMITED_USERS=contractor@external.com,guest@example.com

# ==============================================================================
# SESSION MANAGEMENT (NEW!)
# ==============================================================================

# Enable session management with cookies
ENABLE_SESSIONS=true

# Session timeout in seconds (default: 3600 = 1 hour)
SESSION_TIMEOUT=3600

# ==============================================================================
# GENERAL SETTINGS
# ==============================================================================

# Environment (dev, staging, prod)
ENVIRONMENT=dev

# Enable/disable Cloudflare authentication
# Set to false for local development without Cloudflare
CLOUDFLARE_ENABLED=true

# ==============================================================================
# LEGACY SETTINGS (still supported)
# ==============================================================================

# Optional: Restrict to specific email domains (legacy setting)
# Use WHITELIST instead for more flexibility
# Comma-separated list of allowed email domains
ALLOWED_EMAIL_DOMAINS=example.com,trusted-partner.com

# ==============================================================================
# SECURITY SETTINGS
# ==============================================================================

# Require email verification in JWT claims
REQUIRE_EMAIL_VERIFICATION=true

# Log authentication failures for security monitoring
LOG_AUTH_FAILURES=true

# ==============================================================================
# JWT CONFIGURATION (usually don't need to change these)
# ==============================================================================

# JWT signature algorithm (RS256 for Cloudflare)
JWT_ALGORITHM=RS256

# Maximum number of public keys to cache
JWT_CACHE_MAX_KEYS=10

# Header containing the JWT assertion
JWT_HEADER_NAME=Cf-Access-Jwt-Assertion

# Header containing authenticated user email
EMAIL_HEADER_NAME=Cf-Access-Authenticated-User-Email

# ==============================================================================
# QUICK START EXAMPLES
# ==============================================================================

# Example 1: Allow all users from your company
# WHITELIST=@yourcompany.com
# ADMIN_EMAILS=admin@yourcompany.com
# FULL_USERS=@yourcompany.com

# Example 2: Mix of individual users and domains
# WHITELIST=user1@example.com,user2@example.com,@company.com
# ADMIN_EMAILS=admin@company.com
# FULL_USERS=@company.com
# LIMITED_USERS=contractor@external.com

# Example 3: Development mode (no Cloudflare)
# CLOUDFLARE_ENABLED=false
# ENVIRONMENT=dev
